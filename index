<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>DC BINGO drop checker</title>
<style>
  :root {
    --bg: #0b1020;
    --panel: #10182b;
    --panel-2: #15213a;
    --panel-3: #1b2947;
    --text: #f5f7fb;
    --muted: #a8b4ce;
    --line: rgba(255,255,255,.10);
    --line-2: rgba(255,255,255,.16);
    --accent: #7dd3fc;
    --accent-2: #c084fc;
    --shadow: 0 16px 40px rgba(0,0,0,.30);
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at top left, rgba(125,211,252,.08), transparent 28%),
      radial-gradient(circle at top right, rgba(192,132,252,.08), transparent 25%),
      var(--bg);
    color: var(--text);
  }
  .wrap {
    max-width: 1500px;
    margin: 0 auto;
    padding: 24px;
  }
  .hero {
    display: flex;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  h1 {
    margin: 0;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.05;
  }
  .sub {
    color: var(--muted);
    margin-top: 8px;
    max-width: 920px;
  }
  .summary {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }
  .pill {
    border: 1px solid var(--line);
    background: rgba(255,255,255,.04);
    color: var(--text);
    border-radius: 999px;
    padding: 10px 14px;
    font-size: 14px;
  }
  .controls {
    margin: 18px 0 22px;
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 16px;
  }
  .searchbox, .categorybox {
    background: rgba(255,255,255,.04);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 14px;
    box-shadow: var(--shadow);
  }
  .searchbox input {
    width: 100%;
    background: rgba(0,0,0,.18);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 14px 16px;
    border-radius: 12px;
    outline: none;
    font-size: 15px;
  }
  .searchbox input::placeholder { color: #9fb0cf; }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    border: 1px solid var(--line);
    color: var(--text);
    background: rgba(255,255,255,.05);
    color: var(--text);
    border-radius: 12px;
    padding: 10px 12px;
    cursor: pointer;
    font-size: 14px;
    transition: .18s ease;
  }
  .chip:hover {
    border-color: var(--line-2);
    transform: translateY(-1px);
  }
  .chip.active {
    background: linear-gradient(135deg, rgba(125,211,252,.16), rgba(192,132,252,.16));
    border-color: rgba(125,211,252,.35);
  }

  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(320px, .95fr);
    gap: 20px;
    align-items: start;
  }
  .leftpane, .rightpane {
    min-width: 0;
  }
  .rightpane {
    position: sticky;
    top: 18px;
  }
  .detail {
    background: rgba(255,255,255,.04);
    border: 1px solid var(--line);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .detail-head {
    padding: 18px 18px 14px;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.015));
  }
  .detail h2 {
    margin: 0;
    font-size: 24px;
    line-height: 1.15;
  }
  .muted {
    color: var(--muted);
    font-size: 14px;
    margin-top: 4px;
  }
  .detail-count {
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
  }
  .item-list {
    padding: 14px;
    display: grid;
    gap: 10px;
    max-height: calc(100vh - 260px);
    overflow: auto;
  }
  .item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(255,255,255,.03);
  }
  .item img {
    width: 34px;
    height: 34px;
    object-fit: contain;
    flex: 0 0 auto;
    image-rendering: -webkit-optimize-contrast;
  }
  .item-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .item-name {
    color: var(--text);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.25;
  }
  .item-rate {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.2;
  }

  .category-section {
    margin-bottom: 26px;
  }
  .category-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    margin: 0 0 12px;
    padding: 0 2px;
  }
  .category-header h3 {
    margin: 0;
    font-size: 21px;
  }
  .category-meta {
    color: var(--muted);
    font-size: 14px;
    white-space: nowrap;
  }
  .source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 14px;
  }
  .card {
    border: 1px solid var(--line);
    color: var(--text);
    background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025));
    border-radius: 18px;
    padding: 14px;
    cursor: pointer;
    transition: .18s ease;
    min-height: 158px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--line-2);
    box-shadow: 0 10px 28px rgba(0,0,0,.24);
  }
  .card.active {
    border-color: rgba(125,211,252,.45);
    background: linear-gradient(180deg, rgba(125,211,252,.12), rgba(255,255,255,.03));
    box-shadow: 0 16px 34px rgba(0,0,0,.25);
  }
  .card-top {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .card-top img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 12px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--line);
    padding: 5px;
    flex: 0 0 auto;
  }
  .card-title {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
  }
  .card-sub {
    color: var(--text);
    font-size: 12px;
    margin-top: 4px;
  }
  .card-footer {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--text);
    font-size: 13px;
  }
  .empty {
    color: var(--muted);
    padding: 18px 2px;
  }
  @media (max-width: 1050px) {
    .controls {
      grid-template-columns: 1fr;
    }
    .layout {
      grid-template-columns: 1fr;
    }
    .rightpane {
      position: static;
      order: -1;
    }
    .item-list {
      max-height: none;
    }
  }
</style>
</head>
