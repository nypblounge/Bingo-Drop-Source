images/thumb/Broken_dragon_hook_detail.png/130px-Broken_dragon_hook_detail.png?6966e", "rate": "1/1023"}]}, {"id": "hunter-training", "label": "Hunter Training", "category": "Other", "subtitle": "", "icon": "data:image/png;base64,", "items": [{"taskName": "tecu salamander", "label": "tecu salamander", "img": "https://oldschool.runescape.wiki/images/thumb/Tecu_salamander_detail.png/130px-Tecu_salamander_detail.png?50d08", "rate": "1/1000"}]}, {"id": "shellbane-gryphon", "label": "Shellbane Gryphon", "category": "Other", "subtitle": "", "icon": "data:image/png;base64,", "items": [{"taskName": "Any Jar", "label": "Any Jar", "img": "https://oldschool.runescape.wiki/images/Jar_of_feathers.png?92285", "rate": "1/2000"}]}, {"id": "vampire-krakens", "label": "Vampire Krakens", "category": "Other", "subtitle": "", "icon": "data:image/png;base64,", "items": [{"taskName": "Bottled Storm", "label": "Bottled Storm", "img": "https://oldschool.runescape.wiki/images/thumb/Bottled_storm_detail.png/130px-Bottled_storm_detail.png?6fd35", "rate": "1/500"}]}];
const CATEGORY_ORDER = ["All", "Raids", "Slayer", "Minigames", "God Wars Dungeon", "Wilderness", "Bossing", "f2p", "Desert Treasure 2", "Other"];

const state = {
  search: '',
  category: 'All',
  selectedId: SOURCES[0]?.id || null,
};

function normalize(text) {
  return (text || '').toLowerCase();
}

function sourceMatches(source, search) {
  if (!search) return true;
  const hay = [
    source.label,
    source.subtitle || '',
    ...(source.items || []).map(item => item.label)
  ].join(' ').toLowerCase();
  return hay.includes(search);
}

function filteredSources() {
  const search = normalize(state.search);
  return SOURCES.filter(source => {
    const categoryOk = state.category === 'All' || source.category === state.category;
    const searchOk = sourceMatches(source, search);
    return categoryOk && searchOk;
  });
}

function categoryCounts() {
  const search = normalize(state.search);
  const result = {};
  for (const cat of CATEGORY_ORDER) {
    if (cat === 'All') continue;
    const inCat = SOURCES.filter(s => s.category === cat && sourceMatches(s, search));
    const itemSet = new Set();
    inCat.forEach(s => s.items.forEach(item => itemSet.add(item.taskName)));
    result[cat] = {
      itemCount: itemSet.size,
      sourceCount: inCat.length,
    };
  }
  const allSet = new Set();
  filteredSources().forEach(s => s.items.forEach(item => allSet.add(item.taskName)));
  result['All'] = {
    itemCount: allSet.size,
    sourceCount: filteredSources().length,
  };
  return result;
}

function renderChips() {
  const counts = categoryCounts();
  const chips = document.getElementById('categoryChips');
  chips.innerHTML = '';
  for (const cat of CATEGORY_ORDER) {
    const data = counts[cat] || { itemCount: 0, sourceCount: 0 };
    const btn = document.createElement('button');
    btn.className = 'chip' + (state.category === cat ? ' active' : '');
    btn.textContent = `${cat} · ${data.itemCount}`;
    btn.title = `${data.itemCount} unique items across ${data.sourceCount} source${data.sourceCount === 1 ? '' : 's'}`;
    btn.onclick = () => {
      state.category = cat;
      const currentFiltered = filteredSources();
      if (!currentFiltered.some(s => s.id === state.selectedId)) {
        state.selectedId = currentFiltered[0]?.id || null;
      }
      render();
    };
    chips.appendChild(btn);
  }
}

function renderLeftPane() {
  const root = document.getElementById('leftPane');
  const vis = filteredSources();
  root.innerHTML = '';
  if (!vis.length) {
    root.innerHTML = `<div class="empty">No sources match the current search/filter.</div>`;
    return;
  }

  for (const cat of CATEGORY_ORDER.slice(1)) {
    if (state.category !== 'All' && state.category !== cat) continue;
    const inCat = vis.filter(s => s.category === cat);
    if (!inCat.length) continue;

    const itemSet = new Set();
    inCat.forEach(source => source.items.forEach(item => itemSet.add(item.taskName)));

    const section = document.createElement('section');
    section.className = 'category-section';

    const head = document.createElement('div');
    head.className = 'category-header';
    head.innerHTML = `
      <h3>${cat}</h3>
      <div class="category-meta">${itemSet.size} unique item${itemSet.size === 1 ? '' : 's'} · ${inCat.length} source${inCat.length === 1 ? '' : 's'}</div>
    `;
    section.appendChild(head);

    const grid = document.createElement('div');
    grid.className = 'source-grid';

    inCat.forEach(source => {
      const card = document.createElement('button');
      card.className = 'card' + (state.selectedId === source.id ? ' active' : '');
      card.onclick = () => {
        state.selectedId = source.id;
        renderDetail();
        renderLeftPane();
      };
      card.innerHTML = `
        <div class="card-top">
          <img src="${source.icon}" alt="" />
          <div>
            <div class="card-title">${source.label}</div>
          </div>
        </div>
        <div class="card-footer">
          <span>${source.items.length} item${source.items.length === 1 ? '' : 's'}</span>
          <span>${source.category}</span>
        </div>
      `;
      grid.appendChild(card);
    });

    section.appendChild(grid);
    root.appendChild(section);
  }
}

function renderDetail() {
  const detail = document.getElementById('detail');
  const vis = filteredSources();
  let selected = vis.find(s => s.id === state.selectedId);
  if (!selected) selected = vis[0] || null;
  state.selectedId = selected?.id || null;

  if (!selected) {
    detail.innerHTML = `
      <div class="detail-head">
        <h2>No source selected</h2>
              </div>
    `;
    return;
  }

  detail.innerHTML = `
    <div class="detail-head">
      <h2>${selected.label}</h2>
      <div class="detail-count">${selected.items.length} checked item${selected.items.length === 1 ? '' : 's'}</div>
    </div>
    <div class="item-list">
      ${selected.items.map(item => `
        <div class="item">
          <img src="${item.img}" alt="" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.opacity=.35;this.title='Image failed to load';" />
          <div class="item-meta">
            <span class="item-name">${item.label}</span>
            <span class="item-rate">${item.rate}</span>
          </div>
        </div>
      `).join('')}
    </div>
  `;
}

function renderSummary() {
  const visible = filteredSources();
  const uniqueItems = new Set();
  visible.forEach(s => s.items.forEach(item => uniqueItems.add(item.taskName)));
  document.getElementById('summaryItems').textContent = `${uniqueItems.size} unique checked items shown`;
  document.getElementById('summarySources').textContent = `${visible.length} sources shown`;
}

function render() {
  renderChips();
  renderLeftPane();
  renderDetail();
  renderSummary();
}

document.getElementById('search').addEventListener('input', (e) => {
  state.search = e.target.value.trim();
  const currentFiltered = filteredSources();
  if (!currentFiltered.some(s => s.id === state.selectedId)) {
    state.selectedId = currentFiltered[0]?.id || null;
  }
  render();
});

render();
</script>
